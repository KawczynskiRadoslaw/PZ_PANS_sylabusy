Sub format_italic_text()

Dim iStartes(30) As Variant, iEndes(30) As Variant
Dim i As Integer, j As Integer, k As Integer
Dim text As String

text = ActiveCell.Value

j = 0
k = 0
For i = 1 To Len(text)
If Mid(text, i, 3) = "<i>" Then
iStartes(j) = i
j = j + 1
End If
If Mid(text, i, 4) = "</i>" Then
iEndes(k) = i
k = k + 1
End If
Next

i = 0
j = 0
Do While i < 30
If iStartes(i) <> "" Then
iStartes(i) = iStartes(i) - j
iEndes(i) = iEndes(i) - (j + 3)
j = j + 7
End If
i = i + 1
Loop

ActiveCell.Value = Replace(ActiveCell.Value, "<i>", "")
ActiveCell.Value = Replace(ActiveCell.Value, "</i>", "")

i = 0
Do While i < 30
If iStartes(i) <> "" Then
j = iEndes(i) - iStartes(i)
ActiveCell.Characters(Start:=iStartes(i), Length:=j).Font.Italic = True
End If
i = i + 1
Loop

End Sub
