Sub format_universal_text()

Dim iStartes(30) As Variant, iEndes(30) As Variant, iStartes2(30) As Variant, iEndes2(30) As Variant, iCategory(30) As Variant
Dim i, j, k, m As Integer
Dim text As String

i = 0
Do While i < 30
iStartes(i) = 0
iEndes(i) = 0
iStartes2(i) = 0
iEndes2(i) = 0
i = i + 1
Loop

text = ActiveCell.Value
i = 0
j = 0
k = 0
m = -3
For i = 1 To Len(text)
If Mid(text, i, 3) = "<i>" Or Mid(text, i, 3) = "<b>" Or Mid(text, i, 3) = "<u>" Then
m = m + 3
iStartes(j) = i - m
If Mid(text, i, 3) = "<i>" Then
iCategory(j) = "i"
End If
If Mid(text, i, 3) = "<b>" Then
iCategory(j) = "b"
End If
If Mid(text, i, 3) = "<u>" Then
iCategory(j) = "u"
End If
j = j + 1
End If
If Mid(text, i, 4) = "</i>" Or Mid(text, i, 4) = "</b>" Or Mid(text, i, 4) = "</u>" Then
m = m + 4
k = 0
Do While k < 30
If iStartes(k) > 0 And iEndes(k) = 0 And iCategory(k) = "i" And Mid(text, i, 4) = "</i>" Then
iEndes(k) = i - m
End If
If iStartes(k) > 0 And iEndes(k) = 0 And iCategory(k) = "b" And Mid(text, i, 4) = "</b>" Then
iEndes(k) = i - m
End If
If iStartes(k) > 0 And iEndes(k) = 0 And iCategory(k) = "u" And Mid(text, i, 4) = "</u>" Then
iEndes(k) = i - m
End If
k = k + 1
Loop
End If
Next

ActiveCell.Value = Replace(ActiveCell.Value, "<i>", "")
ActiveCell.Value = Replace(ActiveCell.Value, "</i>", "")
ActiveCell.Value = Replace(ActiveCell.Value, "<b>", "")
ActiveCell.Value = Replace(ActiveCell.Value, "</b>", "")
ActiveCell.Value = Replace(ActiveCell.Value, "<u>", "")
ActiveCell.Value = Replace(ActiveCell.Value, "</u>", "")

i = 0
Do While i < 30
If iStartes(i) > 0 Then
j = (iEndes(i) - iStartes(i)) + 1
If iCategory(i) = "i" Then
ActiveCell.Characters(Start:=iStartes(i), Length:=j).Font.Italic = True
End If
If iCategory(i) = "b" Then
ActiveCell.Characters(Start:=iStartes(i), Length:=j).Font.Bold = True
End If
If iCategory(i) = "u" Then
ActiveCell.Characters(Start:=iStartes(i), Length:=j).Font.Underline = True
End If
End If
i = i + 1
Loop

End Sub
